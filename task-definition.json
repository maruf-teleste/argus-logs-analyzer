{
  "family": "log-analyzer-task",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "2048",
  "memory": "8192",
  "executionRoleArn": "arn:aws:iam::600201706971:role/myEcsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::600201706971:role/logAnalyzerTaskRole",
  "containerDefinitions": [
    {
      "name": "log-analyzer",
      "image": "600201706971.dkr.ecr.eu-north-1.amazonaws.com/log-analyzer-poc-v2:latest",
      "portMappings": [
        {
          "containerPort": 3000,
          "protocol": "tcp"
        }
      ],
      "secrets": [
        {
          "name": "OPENAI_API_KEY",
          "valueFrom": "arn:aws:secretsmanager:eu-north-1:600201706971:secret:log-analyzer/openai-api-key"
        }
      ],
      "environment": [
        {
          "name": "AWS_REGION",
          "value": "eu-north-1"
        },
        {
          "name": "S3_BUCKET_NAME",
          "value": "teleste-log-analyzer-test"
        },
        {
          "name": "SQLITE_PATH",
          "value": "./data/app.sqlite"
        },
        {
          "name": "PARQUET_SAFE_RECOVERY",
          "value": "1"
        },
        {
          "name": "HOSTNAME",
          "value": "0.0.0.0"
        },
        {
          "name": "PORT",
          "value": "3000"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/log-analyzer",
          "awslogs-region": "eu-north-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
